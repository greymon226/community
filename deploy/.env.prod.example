# ===== 由 deploy.sh 自动生成或手工填写 =====
# 复制到仓库根目录的 .env.prod 后再启动

# --- HTTP / 域名 ---
HTTP_PORT=80
PUBLIC_DOMAIN=community.example.com
PUBLIC_BASE_URL=http://124.222.8.86
# 审计日志/限流使用的反向代理层数：Docker 默认 frontend 容器 Nginx 1 层；若前面还有宿主机 Nginx 则设为 2
TRUST_PROXY=1

# --- MCP（留空表示公开演示；填写后需用 Bearer 或 x-mcp-api-key 访问）---
MCP_API_KEY=

# --- 数据库（强烈建议改成强随机串）---
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT
DB_NAME=community
DB_USER=community
DB_PASS=CHANGE_ME_STRONG_DBPASS
# 模型新增字段后可临时设为 1 重启一次，完成表结构补齐后改回空
DB_SYNC_ALTER=

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS

# --- JWT（必须 32+ 字节随机串）---
JWT_SECRET=CHANGE_ME_OPENSSL_RAND_HEX_32

# --- 上传 ---
MAX_UPLOAD_MB=10

# --- 敏感词（逗号分隔，可留空，由后台维护）---
SENSITIVE_WORDS=

# --- AI（不配则进 local 规则模式，AI 解读/问答会不可用）---
AI_PROVIDER=deepseek
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
AI_TIMEOUT_MS=15000

# --- CAS（企业内 CAS 才填，否则保持空走 Mock）---
CAS_SERVER_URL=http://community.example.com:8000/cas/built-in/community
CAS_SERVICE_URL=http://community.example.com/login/cas-callback
CAS_ATTR_EMP_NO=name,user,id
CAS_ATTR_NAME=displayName,name,user
CAS_ATTR_EMAIL=email,mail
CAS_ATTR_DEPARTMENT=department,departmentName,dept
CAS_ATTR_AVATAR=avatar,picture

# --- 内置 Casdoor（默认启用；如使用外部企业 CAS，可设 ENABLE_CASDOOR=0 并改 CAS_SERVER_URL）---
ENABLE_CASDOOR=1
COMPOSE_PROFILES=casdoor
CASDOOR_HTTP_PORT=8000
CASDOOR_PUBLIC_BASE_URL=http://community.example.com:8000
CASDOOR_DB_ROOT_PASSWORD=CHANGE_ME_STRONG_CASDOOR_ROOT
CASDOOR_DB_PASSWORD=CHANGE_ME_STRONG_CASDOOR_DBPASS
CASDOOR_ORGANIZATION=built-in
CASDOOR_APPLICATION=community
CASDOOR_CLIENT_SECRET=CHANGE_ME_OPENSSL_RAND_HEX_32

# --- GitHub OAuth 登录配置（可选） ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=
