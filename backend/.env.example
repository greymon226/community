# 服务端口
PORT=4000

# JWT
JWT_SECRET=please-change-this-secret
JWT_EXPIRES_IN=7d

# 数据库 (mysql | sqlite)
# 推荐 mysql：mysql2 驱动是纯 JS，无需编译
# 如需快速启动 MySQL，请在仓库根目录执行: docker compose up -d
DB_DIALECT=mysql
DB_HOST=127.0.0.1
DB_PORT=3316
DB_NAME=community
DB_USER=root
DB_PASS=community123

# 使用 sqlite 时（需要先 npm install sqlite3）
# DB_DIALECT=sqlite
# DB_STORAGE=./data/community.sqlite

# Redis（可选，未配置则使用内存缓存）
# REDIS_URL=redis://127.0.0.1:6379

# CAS（可选；未配置则启用 Mock 模式）
# CAS_SERVER_URL=https://cas.example.com
# CAS_SERVICE_URL=http://localhost:5173/login/cas-callback

# 上传目录
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# 敏感词配置（逗号分隔，亦可在管理后台维护）
SENSITIVE_WORDS=

# AI 服务（用于内容审核与推荐）
# provider 取值: local（默认本地规则） | deepseek | openai
# AI_PROVIDER=deepseek
# AI_API_KEY=sk-xxxxxxxx           # 在 https://platform.deepseek.com/ 申请
# AI_BASE_URL=https://api.deepseek.com
# AI_MODEL=deepseek-chat           # 也可选 deepseek-reasoner
# AI_TIMEOUT_MS=15000
